# Copy this file to .env and fill in your values

# For local development, SQLite is used automatically when DATABASE_URL is not set
# For production (Supabase), paste your connection string here:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Generate a strong secret key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# JWT token expiry in minutes (default: 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080
